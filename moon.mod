name = "Xpeng/mooncharts"

version = "0.5.0"

readme = "README.mbt.md"

repository = "https://github.com/pxgt/mooncharts"

license = "Apache-2.0"

keywords = [ "svg", "chart", "visualization", "plot", "dataviz", "graphics" ]

description = "Lightweight native SVG charting library for MoonBit — bar, line, pie/donut and scatter charts."
